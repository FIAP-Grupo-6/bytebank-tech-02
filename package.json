{
  "name": "bytebank-fase2",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "dev:host": "npm run dev --workspace=apps/host",
    "dev:transactions": "npm run dev --workspace=apps/transactions",
    "dev:api": "npm run dev --prefix api",
    "dev:full": "concurrently -n API,APPS -c blue,green \"npm run dev:api\" \"npm run dev\"",
    "dev:mock": "node scripts/mock-api/server.js",
    "dev:demo": "concurrently -n MOCK,APPS -c blue,green \"npm run dev:mock\" \"npm run dev\"",
    "storybook": "npm run storybook --workspace=packages/ui"
  },
  "devDependencies": {
    "concurrently": "^9.2.3",
    "prettier": "^3.4.2",
    "turbo": "2.3.3"
  },
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=18"
  }
}
