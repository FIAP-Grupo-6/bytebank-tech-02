{
  "name": "bytebank-fase2",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "dev:host": "npm run dev --workspace=apps/host",
    "dev:transactions": "npm run dev --workspace=apps/transactions",
    "storybook": "npm run storybook --workspace=packages/ui"
  },
  "devDependencies": {
    "turbo": "2.3.3",
    "prettier": "^3.4.2"
  },
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=18"
  }
}
